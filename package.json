{
  "name": "kahoot-horses",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm --workspace server start\" \"npm --workspace client run dev\"",
    "build": "npm --workspace client run build",
    "lint": "npm --workspace client run lint",
    "test": "npm --workspace server test"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
