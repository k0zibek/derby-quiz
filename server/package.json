{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "dev": "tsx index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "classroom": "npm --workspace client run build && npm run build && CLASSROOM_STATIC_DIR=../client/dist node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/server/test/*.test.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "nanoid": "^5.1.6",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  }
}
